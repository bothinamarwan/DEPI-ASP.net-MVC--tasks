@model MVC_Day2.ViewModels.DepartmentAddViewModel

@{
    ViewData["Title"] = "Add Department";
}

<h2 class="mb-4">Add New Department</h2>

<div class="card shadow-sm" style="max-width: 500px;">
    <div class="card-body">
        <form asp-action="Add" method="post">
          
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-bold"></label>
                <input asp-for="Name" class="form-control" placeholder="e.g. Computer Science" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="MgrName" class="form-label fw-bold"></label>
                <input asp-for="MgrName" class="form-control" placeholder="e.g. Dr. Smith" />
                <span asp-validation-for="MgrName" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success">Save Department</button>
                <a asp-action="ShowAll" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />
}
