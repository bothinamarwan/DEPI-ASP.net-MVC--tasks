
@model MVC_Day2.ViewModels.StudentFormViewModel

@{
    ViewData["Title"] = "Student Details";
    var courses = ViewBag.Courses as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}

<h2 class="mb-4">Student Details</h2>

<div class="card shadow-sm" style="max-width:560px;">
    <div class="card-header bg-dark text-white">
        <h5 class="mb-0">@Model.Name</h5>
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">ID</dt>
            <dd class="col-sm-8">@Model.Id</dd>

            <dt class="col-sm-4">Age</dt>
            <dd class="col-sm-8">@Model.Age</dd>

            <dt class="col-sm-4">Department</dt>
            <dd class="col-sm-8">@Model.DepartmentOptions.FirstOrDefault()?.Text</dd>
        </dl>

        <hr />
        <h6>Enrolled Courses</h6>
        @if (courses.Any())
        {
            <table class="table table-sm table-bordered mt-2">
                <thead class="table-secondary">
                    <tr><th>Course</th><th>Grade</th></tr>
                </thead>
                <tbody>
                    @foreach (var c in courses)
                    {
                        <tr>
                            <td>@c.CourseName</td>
                            <td><strong>@c.Grade</strong></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted">Not enrolled in any courses.</p>
        }
    </div>
    <div class="card-footer d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-sm">Edit</a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger btn-sm">Delete</a>
        <a asp-action="GetAll" class="btn btn-secondary btn-sm ms-auto">← Back</a>
    </div>
</div>
