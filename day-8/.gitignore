## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Get latest from https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if you have tasks that create the TestResults folder
#TestResults/

# VS Code
.vscode/

# MSTest test Results
[Tt]est[Rr]esults/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# Build log of MSBuild
*.log

# Entity Framework 6 (deprecated)
*.Migrations.cs

# JetBrains Rider
.idea/
*.sln.iml

# Visual Studio Profiler
*.psess
*.vsp
*.vspx
*.sap

# Visual Studio Trace Log
*.etl

# Backup & checkpoint files
*~
*.bak
*.cache
*.csproj.user
*.user
*.suo
*.vssscc
*.vspscc
*.webinfo
*.dbmdl
*.dbproj.user
*.sqlproj.user
*.config.user
*.publishxml
*.pubxml
*.pubxml.user

# Core
StackTrace.txt

# NuGet Packages
*.nupkg
# NuGet Symbol Packages
*.snupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/
# Uncomment if using NuGet repositories to store project specific packages (not recommended)
# !**/[Pp]ackages/

# Microsoft Azure Build Output
csx/
*.build.csdef

# Microsoft Azure Cloud Service projects
ecf/
rcf/

# Windows Azure Emulator
ServiceDefinition.csdef
ServiceConfiguration.cscfg

# Azure Stream Analytics
ASALocalRun/

# Windows Installer files from build outputs
*.cab
*.msi
*.msm
*.msp

# JetBrains DotTrace Profiler
*.dtp

# ReSharper is a NuGet package and can be safely ignored in most cases.
# It is recommended to use the .DotSettings.user file for project-specific settings.
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# JustMock
*.jmconfig

# TeamCity build version control
_TeamCity*

# Libs
node_modules/
bower_components/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Core
appsettings.Development.json
# Secrets should be ignored
secrets.json

# StyleCop
StyleCop.Cache

# Cake
Tools/
!Tools/packages.config

# Tabs Studio
*.tss

# Telerik
App_Data/*.ldf
App_Data/*.mdf

# Other
Thumbs.db
ehthumbs.db
Desktop.ini
