@model IEnumerable<TaskEvaluate.Models.TaskItem>

@{
    ViewData["Title"] = "Index";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Task Management</h1>
    <div>
        <a asp-action="Create" class="btn btn-primary btn-lg shadow-sm">
            <i class="fas fa-plus"></i> Create New Task
        </a>
        <button id="btnFetchInfo" class="btn btn-outline-info btn-lg shadow-sm ms-2">
            <i class="fas fa-info-circle"></i> Fetch Server Info
        </button>
    </div>
</div>

<div id="infoPanel" class="alert alert-info d-none shadow-sm mb-4 animate__animated animate__fadeIn">
    <strong>Server Status:</strong> <span id="serverMessage"></span>
    <button type="button" class="btn-close float-end" onclick="$('#infoPanel').addClass('d-none')"></button>
</div>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Title)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Description)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.IsCompleted)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CreatedAt)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Title)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Description)
            </td>
            <td>
                <input type="checkbox" class="toggle-complete" data-id="@item.Id" @(item.IsCompleted ? "checked" : "") />
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CreatedAt)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
    <script>
        $(document).ready(function () {
            // Checkbox Toggle AJAX
            $('.toggle-complete').change(function () {
                var id = $(this).data('id');
                var checkbox = $(this);
                var row = checkbox.closest('tr');
                
                $.post('@Url.Action("ToggleComplete", "TaskItem")', { id: id }, function (data) {
                    if (data.success) {
                        if (data.isCompleted) {
                            row.addClass('table-success');
                        } else {
                            row.removeClass('table-success');
                        }
                    } else {
                        alert(data.message);
                        checkbox.prop('checked', !checkbox.prop('checked'));
                    }
                });
            });

            // Button Click AJAX Demo
            $('#btnFetchInfo').click(function () {
                var btn = $(this);
                btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span> Loading...');

                $.get('@Url.Action("GetServerInfo", "TaskItem")', function (data) {
                    $('#serverMessage').text(data.message + " | Current Time: " + data.time);
                    $('#infoPanel').removeClass('d-none').addClass('animate__fadeIn');
                    btn.prop('disabled', false).html('<i class="fas fa-info-circle"></i> Fetch Server Info');
                });
            });
        });
    </script>
}

<style>
    body {
        background-color: #f8f9fa;
        font-family: 'Inter', sans-serif;
    }
    .table {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    }
    .table thead th {
        background-color: #343a40;
        color: white;
        border: none;
    }
    .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
    }
    .btn-primary:hover {
        transform: translateY(-1px);
        box-shadow: 0 7px 14px rgba(50, 50, 93, .1), 0 3px 6px rgba(0, 0, 0, .08);
    }
</style>
