@model IEnumerable<MVC_Day2.Models.Student>

<h2>All Students</h2>

<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Age</th>
            <th>Department</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var student in Model)
        {
            <tr>
                <td>@student.Id</td>
                <td>@student.Name</td>
                <td>@student.Age</td>
                <td>@student.Department?.Name</td>
                <td>
                    <a href="@Url.Action("ShowDetails", "Students", new { id = student.Id })">Details</a> |
                    <a href="@Url.Action("Edit", "Students", new { id = student.Id })">Edit</a> |
                    <a href="@Url.Action("Delete", "Students", new { id = student.Id })">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>